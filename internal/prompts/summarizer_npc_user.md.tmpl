{{ printf "# World: %s\n" .Summarizer.World -}}
{{- $p := .Summarizer.NPCProfile -}}
{{- printf "\n# NPC: %s\n" $p.DisplayName -}}
{{- printf "\n# Current profile (YAML)\n```yaml\ndisplay_name: %s\ntemperament: %s\nrelations_gg: %s\n" $p.DisplayName $p.Temperament $p.RelationsGG -}}
{{- if $p.RelationsNPCs }}relations_npcs:
{{ range $r := $p.RelationsNPCs }}- target: {{ $r.Target }}
  note: {{ $r.Note }}
{{ end }}{{- else }}relations_npcs: []
{{- end -}}
{{- if $p.Abilities }}abilities:
{{ range $a := $p.Abilities }}- {{ $a }}
{{ end }}{{- else }}abilities: []
{{- end -}}
{{- if $p.PersonalMemory }}personal_memory:
{{ range $m := $p.PersonalMemory }}- {{ $m }}
{{ end }}{{- else }}personal_memory: []
{{- end -}}
{{- printf "current_status: %s\n" $p.CurrentStatus -}}
{{- if $p.CriticalKnowledge }}critical_knowledge:
{{ range $k := $p.CriticalKnowledge }}- {{ $k }}
{{ end }}{{- else }}critical_knowledge: []
{{- end -}}
{{- if $p.Nicknames }}nicknames:
{{ range $n := $p.Nicknames }}- {{ $n }}
{{ end }}{{- else }}nicknames: []
{{- end -}}
{{- printf "last_update: %s\n```\n" $p.LastUpdate -}}
{{- if .Summarizer.Chronicle }}
  {{- printf "\n# Полный chronicle (контекст хронологии, без обрезки)\n" -}}
  {{- if .Summarizer.Chronicle.Periods }}periods:
{{ range $pr := .Summarizer.Chronicle.Periods }}- from: {{ $pr.From }}
  to: {{ $pr.To }}
  memory: {{ $pr.Memory }}
{{ end }}{{- else }}periods: []
{{- end -}}
  {{- if .Summarizer.Chronicle.Days }}days:
{{ range $d := .Summarizer.Chronicle.Days }}  {{ $d.Number }}: {{ $d.Text }}
{{ end }}{{- else }}days: {}
{{- end -}}
  {{- printf "\n```\n" }}
{{- end -}}
{{- printf "\nВерни сжатый YAML. Только YAML, без обёрток и комментариев." }}