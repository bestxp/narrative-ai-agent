{{ printf "# World: %s\n" .Summarizer.World -}}
{{- printf "\n# Сжимаемое окно: д%s — д%s (%d дней)\n" (pad5 .Summarizer.StartDay) (pad5 .Summarizer.EndDay) (add1 (sub .Summarizer.EndDay .Summarizer.StartDay)) -}}
{{- printf "\n# Полный chronicle.yaml (используй для контекста и дедупликации пересечений с предыдущими сводками)\n" -}}
{{- if .Summarizer.Chronicle -}}
  {{- if .Summarizer.Chronicle.Periods }}periods:
{{ range $pr := .Summarizer.Chronicle.Periods }}- from: {{ $pr.From }}
  to: {{ $pr.To }}
  memory: {{ $pr.Memory }}
{{ end }}{{- else }}periods: []
{{- end -}}
  {{- if .Summarizer.Chronicle.Days }}days:
{{ range $d := .Summarizer.Chronicle.Days }}  {{ $d.Number }}: {{ $d.Text }}
{{ end }}{{- else }}days: {}
{{- end -}}
{{- else }}periods: []
days: {}
{{- end -}}
{{- printf "\n```\n" -}}
{{- printf "\nВерни ОДИН абзац distilled essence. Без обёрток, без markdown, без префикса." }}